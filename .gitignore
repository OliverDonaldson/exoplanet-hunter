# --- Data + artifacts (large, regeneratable) ---
# Everything under data/ is reproducible: labels.parquet from
# catalog.py, views.npz from build_dataset.py, raw FITS from MAST.
# Anchored to repo root so conf/data/ (the Hydra configs) is NOT ignored.
/data/
models/*.keras
models/*.h5
models/*.joblib
results/
mlruns/
mlartifacts/
# Hydra default output dir (per-run logs + resolved configs)
outputs/
multirun/

# --- lightkurve cache (shared, big) ---
.lightkurve-cache/

# --- IDE ---
.vscode/
.idea/
*.swp
*~
.DS_Store

# --- Secrets ---
.env
.env.*
!.env.example
